---
import '../styles/global.css';
import Navigation, { NavigationLink } from '../components/Navigation'
import { ClientRouter } from 'astro:transitions';
import { TypographyH1 } from '@/components/ui/Typography';

const {title} = Astro.props;
---
<!doctype html>
<html lang="fr">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<ClientRouter/>
	</head>
	<body class="bg-background text-foreground">
		<Navigation>
			<NavigationLink name="accueil" path={new URL('/', Astro.url)}/>
			<NavigationLink name="mes projets" path={new URL('projets', Astro.url)}/>
		</Navigation>
		<main class="page-wrap min-h-svh">
			<slot />
		</main>

		<footer class="bg-card-foreground min-h-8 p-8 text-card">
			<div class="page-wrap">
				
			</div>
		</footer>
	</body>
</html>