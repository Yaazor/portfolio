---
import '../styles/global.css';
import Navigation, { NavigationLink } from '../components/Navigation'
import { ClientRouter, slide } from 'astro:transitions';
import { StrictMode } from 'react';

const {title} = Astro.props;
---
<!doctype html>
<html lang="fr">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<ClientRouter/>
	</head>
	<body class="bg-background text-foreground">
		<StrictMode>
			<Navigation>
				<NavigationLink name="accueil" path={new URL('/', Astro.url)}/>
				<NavigationLink name="mes projets" path="/projets"/>
			</Navigation>
			<main class="min-h-svh" transition:animate={slide({duration: ".4s"})}>
				<slot />
			</main>

			<footer class="bg-card-foreground min-h-8 p-8 text-card">
				<div class="page-wrap">
					
				</div>
			</footer>
		</StrictMode>
	</body>
</html>