---
interface Props {
    isCarousel: boolean
}


import herobrinefrImage from "../assets/projects/herobrinefr.png"
import herobrineServicesImage from "../assets/projects/herobrinefr-services.png"
import portfolioImage from "../assets/projects/portfolio.png"
import ProjectList from "./ProjectList";

const {isCarousel = false} = Astro.props

---

<div>
    <ProjectList client:load projects={[
        {
            title: "Herobrine.fr - Site",
            image: herobrinefrImage,
            technologies: [
                "Symfony", "MySQL", "Tailwind / Sass"
            ],
            description: [
                "Refonte d'une application web sortie en 2012 et accueillant plus de 24 000 inscrits.",
            ],
            href: "/projets/herobrinefr/website"
        },
        {
            title: "Herobrine.fr - Services",
            image: herobrineServicesImage,
            technologies: [
                "Go", "WebSocket", "Typescript"
            ],
            description: [
                "Création de services tels qu'une chatbox WebSocket et un client API écrits en Go.",
            ],
            href: "/projets/herobrinefr/services"
        },
        {
            title: "Portfolio",
            technologies: [
                "Astro", "Typescript", "React"
            ],
            description: [
                "Création d'un portfolio répertoriant certains de mes projets."
            ],
            image: portfolioImage,
            href: "https://github.com/Yaazor/portfolio"
        }
    ]} isCarousel={isCarousel}/>
</div>